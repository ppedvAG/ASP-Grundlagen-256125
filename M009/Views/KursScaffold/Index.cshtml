@model IEnumerable<Kurse>

<!DOCTYPE html>

<html>
<head>
	<meta name="viewport" content="width=device-width" />
	<title>Index</title>
</head>
<body>
	<p>
		<a asp-action="Create">Create New</a>
	</p>
	<table class="table">
		<thead>
			<tr>
				<th>
					@Html.DisplayNameFor(model => model.KursName)
				</th>
				<th>
					@Html.DisplayNameFor(model => model.DauerInTagen)
				</th>
				<th>
					@Html.DisplayNameFor(model => model.Aktiv)
				</th>
				<th></th>
			</tr>
		</thead>
		<tbody>
			@{
				int x = 0;
				foreach (var item in Model)
				{
					<tr class="@(x % 2 == 0 ? "table-primary" : "")">
						<td>
							@Html.DisplayFor(modelItem => item.KursName)
						</td>
						<td>
							@Html.DisplayFor(modelItem => item.DauerInTagen)
						</td>
						<td>
							@Html.DisplayFor(modelItem => item.Aktiv)
						</td>
						<td>
							<a asp-action="Edit" asp-route-id="@item.ID">Edit</a> |
							<a asp-action="Details" asp-route-id="@item.ID">Details</a> |
							<a asp-action="Delete" asp-route-id="@item.ID">Delete</a>
						</td>
					</tr>
					x++;
				}
			}
		</tbody>
	</table>
</body>
</html>
