@*
	@model

	Definiert den Datentypen, der Daten die ans Frontend weitergeleitet werden
	Standard: dynamic
	WICHTIG: model mit kleinem m
*@

@model User

@if (Model == null)
{
	<p>Hallo</p>
	<br/>
	<a asp-action="Einloggen">Einloggen</a>
	<br />
	<a asp-action="Registrieren">Registrieren</a>
}
else
{
	<p>Hallo @Model.UserName</p>
}
